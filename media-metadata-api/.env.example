# ──────────────────────────────────────────────
# media-metadata-api — Environment Variables
# Copy to .env and fill in real values.
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL (used by Prisma)
DATABASE_URL=postgresql://media_user:media_pass@localhost:5432/media_db

# Storage — absolute or relative path where uploaded files are saved
UPLOAD_DIR=./uploads

# Maximum upload size in bytes (default 500 MB)
MAX_FILE_SIZE_BYTES=524288000

# Allowed MIME types (comma-separated, leave empty to allow all)
# ALLOWED_MIME_TYPES=audio/mpeg,image/jpeg,image/png,video/mp4

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info
